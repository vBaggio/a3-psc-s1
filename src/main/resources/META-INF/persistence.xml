<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="projectapp-pu" transaction-type="RESOURCE_LOCAL">

        <class>com.vbaggio.projectapp.model.entity.Cargo</class>
        <class>com.vbaggio.projectapp.model.entity.Usuario</class>
        <class>com.vbaggio.projectapp.model.entity.Projeto</class>
        <class>com.vbaggio.projectapp.model.entity.Equipe</class>
        <class>com.vbaggio.projectapp.model.entity.Tarefa</class>

        <properties>
            <!-- Hibernate: comportamento e logging -->
            <!-- As credenciais de conexão são injetadas em runtime pelo JpaUtil via db.properties -->
            <property name="hibernate.dialect"    value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql"   value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <!-- validate: Hibernate não altera o schema, Flyway e quem controla -->
            <property name="hibernate.hbm2ddl.auto" value="validate"/>
        </properties>

    </persistence-unit>

</persistence>
